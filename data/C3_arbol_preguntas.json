      "respuestas": {
        "si_dejo": {
          "texto": "Sí, siempre priorizo a quien sufre",
          "siguiente": "pregunta5",
          "delta": 5
        },
        "depende_energia": {
          "texto": "Si tengo energía, sí",
          "siguiente": "pregunta5",
