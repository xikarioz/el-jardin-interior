  "tortuga": {
    "presentacion": "La Tortuga te mira con calma. 'Antes de seguir, quiero conocerte un poco. No apures las respuestas. El jardín tiene tiempo.'",
    "pregunta1": {
      "id": "tortuga_resolucion",
      "texto": "¿Qué es lo que más te gusta de cómo resolvés las cosas?",
      "target_trait": "conscientiousness",
      "respuestas": {
        "paciencia": {
          "texto": "Que voy paso a paso sin apurarme",
          "siguiente": "pregunta2",
          "delta": 5
        },
        "rapidez": {
          "texto": "Que resuelvo rápido y no me enredo",
          "siguiente": "pregunta3",
          "delta": -2
        },
        "no_se": {
          "texto": "Nunca lo pensé, no sé",
          "siguiente": "pregunta4",
          "delta": 0
        }
      }
    },
    "pregunta2": {
      "id": "tortuga_fracaso",
      "texto": "Cuando algo no sale como esperabas, ¿qué hacés primero?",
      "target_trait": "neuroticism",
      "respuestas": {
        "analizar": {
          "texto": "Trato de entender qué pasó",
          "siguiente": "pregunta3",
          "delta": -3
        },
        "enojar": {
          "texto": "Me enojo y necesito un momento",
          "siguiente": "pregunta4",
          "delta": 5
        },
        "seguir": {
          "texto": "Busco otro camino directo",
          "siguiente": "pregunta5",
          "delta": -2
        }
      }
    },
    "pregunta3": {
      "id": "tortuga_plan",
      "texto": "¿Qué preferís: tener todo planeado o dejar que fluya?",
      "target_trait": "openness",
      "respuestas": {
        "planeado": {
          "texto": "Planear me da tranquilidad",
          "siguiente": "pregunta4",
          "delta": -3
        },
        "fluir": {
          "texto": "Lo mejor surge sin planear",
          "siguiente": "pregunta5",
          "delta": 5
        },
        "depende": {
          "texto": "Depende de qué se trate",
          "siguiente": "alternativa_zorro_p1",
          "delta": 2
        }
      }
    },
    "pregunta4": {
      "id": "tortuga_critica",
      "texto": "Cuando alguien te critica, ¿cómo reaccionás?",
      "target_trait": "agreeableness",
      "respuestas": {
        "escuchar": {
          "texto": "Escucho, a veces aprendo algo",
          "siguiente": "pregunta5",
          "delta": 5
        },
        "defender": {
          "texto": "Me pongo a la defensiva",
          "siguiente": "pregunta5",
          "delta": -3
        },
        "ignorar": {
          "texto": "Depende de quién venga",
          "siguiente": "alternativa_buho_p1",
          "delta": 1
        }
      }
    },
    "pregunta5": {
      "id": "tortuga_energia",
      "texto": "¿Qué te da más energía: estar con otros o estar solo?",
      "target_trait": "extraversion",
      "respuestas": {
        "otros": {
          "texto": "Estar con gente me recarga",
          "siguiente": "cierre",
          "delta": 5
        },
        "solo": {
          "texto": "Mi tiempo a solas es sagrado",
          "siguiente": "cierre",
          "delta": -3
        },
        "equilibrio": {
          "texto": "Los dos, según el momento",
          "siguiente": "cierre",
          "delta": 1
        }
      }
    }
  },
  "zorro": {
    "presentacion": "El Zorro se sienta en una rama baja, moviendo la cola. 'Te vi moverte por el bosque. Quiero preguntarte algo.'",
