        "me_cuesta": {
          "texto": "Me cuesta, no sé bien qué hacer",
          "siguiente": "alternativa_mariposa_p1",
          "delta": -3
        }
      }
    },
    "pregunta5": {
      "id": "zorro_cambio",
      "texto": "Cuando todo cambia de repente, ¿cómo te sentís?",
      "target_trait": "neuroticism",
      "respuestas": {
        "tranquilo": {
          "texto": "Lo tomo con calma, me adapto",
          "siguiente": "cierre",
          "delta": -4
        },
        "ansioso": {
          "texto": "Me pongo ansioso, necesito tiempo",
          "siguiente": "cierre",
          "delta": 5
        },
        "emociones": {
          "texto": "Siento de todo, pero lo proceso",
          "siguiente": "cierre",
          "delta": 2
        }
      }
    }
