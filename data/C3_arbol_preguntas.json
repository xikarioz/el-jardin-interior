        "depende": {
          "texto": "Depende del cambio",
          "siguiente": "pregunta5",
          "delta": 1
        }
      }
    },
    "pregunta3": {
      "id": "zorro_grupo",
      "texto": "En un grupo, ¿participás activamente o escuchás más?",
      "target_trait": "extraversion",
      "respuestas": {
        "participar": {
          "texto": "Participo, me gusta opinar",
          "siguiente": "pregunta4",
          "delta": 5
        },
        "escuchar": {
          "texto": "Escucho casi todo el tiempo",
